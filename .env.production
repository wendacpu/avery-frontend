# 生产环境配置 - Vercel
#
# 重要：以下环境变量应该在 Vercel 项目设置中配置，而不是提交到代码库
# 访问：https://vercel.com/dashboard → 你的项目 → Settings → Environment Variables
#
# 必需的环境变量：
# NEXTAUTH_URL=https://www.averycmo.com
# NEXTAUTH_SECRET=<运行 openssl rand -base64 32 生成的密钥>
# GOOGLE_CLIENT_ID=<你的 Google OAuth 客户端 ID>
# GOOGLE_CLIENT_SECRET=<你的 Google OAuth 客户端密钥>

NEXT_PUBLIC_API_URL=https://avery-backend-production.up.railway.app/api/v1
